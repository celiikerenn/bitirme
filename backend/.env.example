# FastAPI + MySQL — kopyala: copy .env.example .env  (Windows: copy .env.example .env)
# Bu dosya repoda kalır; .env asla commitlenmez.

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=finance_tracker
# Alternatif isim (kod ikisini de kabul eder):
# MYSQL_DB=finance_tracker

# Windows Tesseract yolu; kurulumuna göre değiştir
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
